{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "types",
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext"
  },
  "include": [
    "index.js",
    "convert/**/*.js",
    "parse/**/*.js",
    "util/**/*.js"
  ],
  "exclude": [
    "test/**"
  ]
}
